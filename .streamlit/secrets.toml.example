# .streamlit/secrets.toml.example
#
# On Streamlit Community Cloud:
#   App dashboard → Settings → Secrets → paste the contents (without the .example suffix)
#
# For local development:
#   Copy to .streamlit/secrets.toml  (it is git-ignored by default)
#   OR keep using .env — both are supported.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Optional overrides ────────────────────────────────────────────────────────
# LLM_PROVIDER = "anthropic"   # "anthropic" | "bedrock"
# LOG_LEVEL    = "INFO"
